# SealedStellar indexer configuration. All values have testnet defaults, so the
# service runs with no .env at all. Override only what you need. TESTNET ONLY.

# Soroban RPC endpoint (must be a testnet endpoint).
RPC_URL=https://soroban-testnet.stellar.org

# The standing auction contract to index (sourceRef: web/src/config.ts).
AUCTION_CONTRACT_ID=CB5MMHVHPKG65D2DYO7HVGBDCMQIDEYP2O7DK5EYPYJUDZQXHWAJJDJ4

# HTTP server port and the web origins allowed by CORS (comma separated).
PORT=8787
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite database file (created on first run).
DATABASE_PATH=./data/indexer.db

# Safety cap on the startup backfill probe over the dense auction id space.
BACKFILL_MAX_ID=1000

# Live ingestion poll cadence in milliseconds (testnet closes ledgers ~5s).
POLL_INTERVAL_MS=5000
