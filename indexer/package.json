{
  "name": "sealedstellar-indexer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Read-only off-chain indexer for the SealedStellar auction contract: ingests the contract events into SQLite and serves a paginated, filterable auctions API. Testnet only.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@stellar/stellar-sdk": "^16.0.1",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
