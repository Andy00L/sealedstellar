# Build artifacts. Exception (decision 2026-06-12, docs/DECISIONS.md): the
# final proving zkey and vkey.json are distribution artifacts; a regenerated
# zkey cannot verify against the deployed verifier instance.
circuits/build/*
!circuits/build/aw_final.zkey
!circuits/build/vkey.json

# Regenerated by every soroban-sdk test run
test_snapshots/

# Design handoff (drew-provided visual spec, not distributed with the repo).
# Covers every exported handoff bundle, e.g. stellar-handoff.zip and
# "Hackathon UI with Glass Effects-handoff.zip".
*-handoff.zip
design-handoff/

# Internal UI design-system handoff (kept local, not distributed with the repo).
docs/UI_DESIGN_SYSTEM.md
contracts/target/
target/
node_modules/

# Circuit assets copied into the web app at predev/prebuild for the browser
# prover (derived from circuits/build, which is the committed source).
web/public/circuit/

# Local environment files: documented in .env.example, never committed
.env

# Operator box keys, whitelist member lists, and bid backups for the standing
# demo instance (decision 2026-06-12, docs/DECISIONS.md). Durable, local-only,
# never committed, never under /tmp.
secrets/

# Windows-side metadata that WSL file copies pick up
*Zone.Identifier
