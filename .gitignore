# Build artifacts. Exception (decision 2026-06-12, docs/DECISIONS.md): the
# final proving zkey and vkey.json are distribution artifacts; a regenerated
# zkey cannot verify against the deployed verifier instance.
circuits/build/*
!circuits/build/aw_final.zkey
!circuits/build/vkey.json

# Regenerated by every soroban-sdk test run
test_snapshots/
contracts/target/
target/
node_modules/

# Local environment files: documented in .env.example, never committed
.env

# Windows-side metadata that WSL file copies pick up
*Zone.Identifier
