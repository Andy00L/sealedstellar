# SealedStellar environment variables (documentation only; the project needs
# no .env file for normal operation). Never commit a real .env.

# Set to 1 to let circuits/scripts/setup.sh overwrite the committed proving
# key. Only do this if you intend to deploy a fresh verifier instance: a
# regenerated zkey cannot verify against the currently deployed one.
SEALEDSTELLAR_FORCE_SETUP=0
